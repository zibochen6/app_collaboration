services:
  {{SOLUTION_ID}}:
    image: {{DOCKER_IMAGE}}
    container_name: {{SOLUTION_ID}}
    restart: unless-stopped
    runtime: nvidia
    network_mode: host
    ipc: host
    privileged: {{PRIVILEGED_FLAG}}
    stdin_open: true
    tty: true
    environment:
      - DISPLAY=${DISPLAY:-:0}
      - QT_X11_NO_MITSHM=1
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=all
      - TZ=${TZ:-Asia/Shanghai}
{{CAMERA_VOLUME_BLOCK}}
{{EXTRA_VOLUME_BLOCK}}
    command:
      - bash
      - -lc
      - |
{{APP_START_COMMAND_BLOCK}}

